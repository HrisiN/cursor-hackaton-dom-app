# Supabase (same project, use service_role key for writes)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Google APIs (server-side — geocoding + places)
GOOGLE_MAPS_SERVER_KEY=your-server-api-key

# Index Oglasi (scraping/adapters/index_adapter.py)
# INDEX_OFFLINE=1 — fixtures/index_fallback.json only (no HTTP)
# INDEX_MAX_SALE=30 — max prodaja stanova rows (default 30)
# INDEX_MAX_RENT=30 — max najam stanova rows (default 30)
# INDEX_MAX_LISTINGS — if set, overrides BOTH sale and rent counts (legacy)
# INDEX_SEARCH_URL — default sale search; use full browser URL with searchQuery (Zagreb filter)
# INDEX_SEARCH_URL_SALE / INDEX_SEARCH_URL_RENT — override per deal type
# INDEX_SEARCH_QUERY_EXTRA — JSON merged into both searches, e.g. {"cityId":"..."} from DevTools
# INDEX_MODULE_ID — UUID from Network → widget-search body.module (often required for 200)
# INDEX_BATCH_DELAY=2 — seconds before/after widget-search and between sale vs rent (polite pacing)
# INDEX_ENRICHMENT_DELAY=1.5 — seconds after each single-ad detail call (default ~1.5s; raise if needed)
# INDEX_BROWSER_FALLBACK=1 — use Playwright when direct API calls are blocked
# INDEX_PLAYWRIGHT_HEADLESS=0 — headed mode (more human-like); set 1 for headless
# INDEX_PLAYWRIGHT_WARMUP_SEC=8 — wait on page before API call to let anti-bot scripts settle
# INDEX_PLAYWRIGHT_MANUAL_SECONDS=0 — headed extra wait for manual challenge solve (if needed)
# INDEX_PLAYWRIGHT_PROFILE_DIR=... — optional persistent browser profile path
# INDEX_SKIP_DETAIL=1 — skip single-ad; list endpoint only (faster, less complete)
